OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-5.4-mini,gpt-5.4,gpt-5.5
