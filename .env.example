HOST=127.0.0.1
PORT=3000
CLIENT_ORIGIN=http://localhost:4200
ASSISTANT_DATA_DIR=.assistant-data
ASSISTANT_AGENT_ID=scotty
ASSISTANT_AGENT_NAME=Scotty
RDMA26_USERNAME=
RDMA26_PASSWORD=
RDMA26_SESSION_SECRET=
